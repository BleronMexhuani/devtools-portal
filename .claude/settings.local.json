{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npm create:*)",
      "Bash(npx create-vite@latest frontend-tmp --template react-ts)",
      "Bash(cp frontend-tmp/tsconfig*.json frontend-tmp/vite.config.ts frontend-tmp/index.html frontend/)",
      "Bash(cp -r frontend-tmp/public frontend/)",
      "Bash(npx vite:*)",
      "Bash(npx eslint:*)",
      "Bash(ls frontend/eslint*)",
      "Bash(ls frontend/*.config.*)"
    ]
  }
}
